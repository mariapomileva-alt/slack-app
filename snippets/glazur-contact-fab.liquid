{%- unless settings.fab_chat_enabled -%}
{%- else -%}
  {%- assign fab_phone = settings.fab_chat_phone | strip -%}
  {%- if fab_phone == blank -%}
    {%- assign fab_phone = '+1 (786) 212-5294' -%}
  {%- endif -%}
  {%- assign tel_core = fab_phone
    | replace: ' ', ''
    | replace: '(', ''
    | replace: ')', ''
    | replace: '-', ''
  -%}
  {%- assign wa_digits = tel_core | remove: '+' -%}
  {%- assign wa_href = settings.social_whatsapp -%}
  {%- if wa_href == blank -%}
    {%- assign wa_href = 'https://wa.me/' | append: wa_digits -%}
  {%- endif -%}
  {%- assign tel_href = 'tel:' | append: tel_core -%}
  {%- assign tg_href = settings.social_telegram -%}
  {%- assign fab_title = settings.fab_chat_title | strip -%}
  {%- if fab_title == blank -%}
    {%- assign fab_title = 'Мы всегда рядом!' -%}
  {%- endif -%}

  <div class="glazur-fab" id="glazur-contact-fab">
    <button
      type="button"
      class="glazur-fab__trigger"
      id="glazur-fab-open"
      aria-haspopup="dialog"
      aria-expanded="false"
      aria-controls="glazur-fab-panel"
    >
      <span class="sr-only">{{ fab_title | escape }}</span>
      <svg class="glazur-fab__icon" width="26" height="26" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/>
      </svg>
    </button>

    <div
      class="glazur-fab__modal"
      id="glazur-fab-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="glazur-fab-title"
      hidden
    >
      <div class="glazur-fab__backdrop" id="glazur-fab-backdrop" tabindex="-1"></div>
      <div class="glazur-fab__sheet">
        <button type="button" class="glazur-fab__close" id="glazur-fab-close" aria-label="Закрыть">
          <span aria-hidden="true">&times;</span>
        </button>
        <h2 class="glazur-fab__title" id="glazur-fab-title">{{ fab_title | escape }}</h2>
        <ul class="glazur-fab__actions" role="list">
          {%- if tg_href != blank -%}
            <li>
              <a class="glazur-fab__action" href="{{ tg_href | escape }}" rel="noopener noreferrer" target="_blank">
                <span class="glazur-fab__circle glazur-fab__circle--tg" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path fill="#fff" d="M2.01 21 L23 12 L2.01 3 L2 10 l15 2 l-15 2 z" />
                  </svg>
                </span>
                <span class="glazur-fab__label">Telegram</span>
              </a>
            </li>
          {%- endif -%}
          <li>
            <a class="glazur-fab__action" href="{{ tel_href | escape }}">
              <span class="glazur-fab__circle glazur-fab__circle--phone" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path fill="#fff" d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              </span>
              <span class="glazur-fab__label">Телефон</span>
            </a>
          </li>
          <li>
            <a class="glazur-fab__action" href="{{ wa_href | escape }}" rel="noopener noreferrer" target="_blank">
              <span class="glazur-fab__circle glazur-fab__circle--wa" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path fill="#fff" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </span>
              <span class="glazur-fab__label">WhatsApp</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
{%- endunless -%}
