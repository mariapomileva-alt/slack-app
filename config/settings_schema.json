[
  {
    "name": "theme_info",
    "theme_name": "Glazur (Greku Future)",
    "theme_version": "0.1.0",
    "theme_author": "Maria Greku",
    "theme_documentation_url": "https://github.com/",
    "theme_support_url": "https://help.shopify.com/"
  },
  {
    "name": "Brand & contact",
    "settings": [
      {
        "type": "text",
        "id": "contact_email",
        "label": "Contact email",
        "default": "info@glazurshop.com"
      },
      {
        "type": "header",
        "content": "Social links (header/footer)"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram"
      },
      {
        "type": "url",
        "id": "social_threads",
        "label": "Threads"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook"
      },
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube"
      },
      {
        "type": "url",
        "id": "social_pinterest",
        "label": "Pinterest"
      },
      {
        "type": "paragraph",
        "content": "Header uses round icons (Telegram, VK, email, WhatsApp, account). Fill URLs below; empty icons are hidden except email and account."
      },
      {
        "type": "url",
        "id": "social_telegram",
        "label": "Telegram (header)"
      },
      {
        "type": "url",
        "id": "social_vk",
        "label": "VK (header)"
      },
      {
        "type": "url",
        "id": "social_whatsapp",
        "label": "WhatsApp (https://wa.me/… )"
      },
      {
        "type": "url",
        "id": "social_profile_url",
        "label": "Account / profile link",
        "info": "If empty, uses the store customer login URL."
      },
      {
        "type": "header",
        "content": "Catalog collections (optional)"
      },
      {
        "type": "paragraph",
        "content": "Pick collections for each line in the nav and catalog band. If empty, links fall back to All products."
      },
      {
        "type": "collection",
        "id": "collection_default",
        "label": "Full collection / default"
      },
      {
        "type": "collection",
        "id": "collection_new_arrivals",
        "label": "New in"
      },
      {
        "type": "collection",
        "id": "collection_blouses",
        "label": "Blouses"
      },
      {
        "type": "collection",
        "id": "collection_stripes",
        "label": "Parisian stripe tops"
      },
      {
        "type": "collection",
        "id": "collection_skirts",
        "label": "Skirts"
      },
      {
        "type": "collection",
        "id": "collection_dresses",
        "label": "Dresses"
      },
      {
        "type": "collection",
        "id": "collection_knitwear",
        "label": "Knitwear"
      },
      {
        "type": "header",
        "content": "Help pages (footer)"
      },
      {
        "type": "paragraph",
        "content": "Pick the store pages for Size guide, Care, and FAQ. Until pages exist, create them under Online Store → Pages, then select them here. If left empty, links use /pages/size-guide, /pages/care, and /pages/faq."
      },
      {
        "type": "page",
        "id": "footer_page_size_guide",
        "label": "Size guide page"
      },
      {
        "type": "page",
        "id": "footer_page_care",
        "label": "Care page"
      },
      {
        "type": "page",
        "id": "footer_page_faq",
        "label": "FAQ page"
      },
      {
        "type": "header",
        "content": "Size guide — diagrams"
      },
      {
        "type": "paragraph",
        "content": "Images appear on the Size guide page after the Chest, Waist, and Hips text. Upload placeholders now and replace with final size graphics anytime — no code edits."
      },
      {
        "type": "image_picker",
        "id": "size_guide_diagram_full",
        "label": "Full-width diagram (optional)",
        "info": "One wide illustration (e.g. full body / all measurements). Shown above the three-column row when set."
      },
      {
        "type": "image_picker",
        "id": "size_guide_img_chest",
        "label": "Image — Chest / bust"
      },
      {
        "type": "image_picker",
        "id": "size_guide_img_waist",
        "label": "Image — Waist"
      },
      {
        "type": "image_picker",
        "id": "size_guide_img_hips",
        "label": "Image — Hips"
      }
    ]
  },
  {
    "name": "Promo bar & modal",
    "settings": [
      {
        "type": "text",
        "id": "promo_bar_text",
        "label": "Promo bar text",
        "default": "Transform Your Day — Get 10% Off Your First Order"
      },
      {
        "type": "text",
        "id": "promo_modal_title",
        "label": "Modal title",
        "default": "Bonjour!"
      },
      {
        "type": "textarea",
        "id": "promo_modal_subline",
        "label": "Modal subline",
        "default": "Subscribe to receive your personal code and discover how Glazur can make everyday beautiful."
      },
      {
        "type": "text",
        "id": "promo_modal_cta",
        "label": "Modal button",
        "default": "Get My 10% Off"
      },
      {
        "type": "textarea",
        "id": "promo_legal",
        "label": "Legal line (modal & footer)",
        "default": "By subscribing, you agree to receive marketing emails. Unsubscribe anytime."
      },
      {
        "type": "text",
        "id": "promo_success_message",
        "label": "Success message (after signup attempt)",
        "default": "Thank you — check your inbox."
      }
    ]
  },
  {
    "name": "Floating contact",
    "settings": [
      {
        "type": "checkbox",
        "id": "fab_chat_enabled",
        "label": "Show floating contact button",
        "default": true
      },
      {
        "type": "text",
        "id": "fab_chat_title",
        "label": "Panel title",
        "default": "Мы всегда рядом!"
      },
      {
        "type": "text",
        "id": "fab_chat_phone",
        "label": "Phone (tap-to-call & WhatsApp)",
        "default": "+1 (786) 212-5294"
      },
      {
        "type": "paragraph",
        "content": "Telegram uses the “Telegram (header)” URL under Brand & contact. If “WhatsApp” URL there is empty, WhatsApp opens wa.me using the phone number above."
      }
    ]
  }
]
