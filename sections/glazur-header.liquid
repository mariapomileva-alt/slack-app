{%- unless settings.promo_bar_enabled == false -%}
  <div id="promo-bar" class="promo-bar">
    <button type="button" class="promo-bar__open" id="promo-open-modal" aria-haspopup="dialog">
      <span id="promo-headline">{{ settings.promo_bar_text | escape }}</span>
    </button>
    <button type="button" class="promo-bar__close" id="promo-close" aria-label="Dismiss promotion">×</button>
  </div>
{%- endunless -%}

<header class="site-header site-header--mirror site-header--shopru">
  <div class="site-header__inner site-header__inner--shopru">
    <nav class="nav" id="site-nav" aria-label="Primary">
      <a href="{% if pages.about != blank %}{{ pages.about.url }}{% else %}{{ routes.root_url }}{% endif %}">About</a>
      <details class="nav-details">
        <summary class="nav-details__summary">Catalog</summary>
        <div class="nav-details__panel" role="group" aria-label="Catalog categories">
          <a href="{% render 'glazur-collection-url', key: 'blouses' %}">Blouses</a>
          <a href="{% render 'glazur-collection-url', key: 'stripes' %}">Parisian stripe tops</a>
          <a href="{% render 'glazur-collection-url', key: 'skirts' %}">Skirts</a>
          <a href="{% render 'glazur-collection-url', key: 'default' %}">Full collection</a>
        </div>
      </details>
      <a class="js-config-mailto" href="mailto:{{ settings.contact_email | escape }}">Contact</a>
      <a class="nav__story" href="{{ routes.root_url }}#story">Stories</a>
      <div class="nav__cta">
        <a class="btn btn--fill" href="{{ routes.all_products_collection_url }}">Order</a>
      </div>
    </nav>
    <a class="logo" href="{{ routes.root_url }}">
      <img
        class="logo__img"
        src="{{ 'glazur-logo-yellow-swan.png' | asset_url }}"
        width="260"
        height="51"
        alt="{{ shop.name }}"
        decoding="async"
        loading="eager"
      >
    </a>
    <a class="header-cart" href="{{ routes.cart_url }}" aria-label="Cart{% if cart.item_count > 0 %}, {{ cart.item_count }} items{% endif %}">
      <svg class="header-cart__icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zm10 0c-1.1 0-1.99.9-1.99 2S15.9 22 17 22s2-.9 2-2-.9-2-2-2zM7.17 14h9.86c.75 0 1.41-.41 1.75-1.03l3.58-6.49a1 1 0 0 0-.88-1.48H5.21l-.94-2H1v2h2l3.6 7.59-1.35 2.44C4.52 16.37 5.48 18 7 18h12v-2H7l1.17-2z"/>
      </svg>
      {% if cart.item_count > 0 %}
        <span class="header-cart__count" aria-hidden="true">{{ cart.item_count }}</span>
      {% endif %}
    </a>
    {% render 'glazur-social-round-icons' %}
    <button type="button" class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="site-nav">Menu</button>
  </div>
</header>

{%- unless settings.promo_bar_enabled == false -%}
  <div id="promo-modal" class="promo-modal" hidden>
    <div class="promo-modal__overlay" aria-hidden="true"></div>
    <div class="promo-modal__panel" role="dialog" aria-modal="true" aria-labelledby="promo-dialog-title">
      <button type="button" class="promo-modal__close" aria-label="Close">×</button>
      <h2 id="promo-dialog-title">{{ settings.promo_modal_title | escape }}</h2>
      <p class="sub" id="promo-subline">{{ settings.promo_modal_subline | escape }}</p>
      {% form 'customer', id: 'promo-form' %}
        {% if form.posted_successfully? %}
          <div id="promo-success" class="success" data-open-on-load="true">
            <p>{{ settings.promo_success_message | escape }}</p>
            {% if settings.promo_discount_code != blank %}
              <p><strong>{{ settings.promo_discount_code | escape }}</strong></p>
              <p>Use this code at checkout.</p>
            {% endif %}
          </div>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter, glazur-site, promo-popup">
          <label class="sr-only" for="promo-email">Email</label>
          <input
            id="promo-email"
            type="email"
            name="contact[email]"
            required
            placeholder="Your email"
            autocomplete="email"
            value="{% if form.email %}{{ form.email }}{% endif %}"
          >
          <button type="submit" class="btn btn--fill" style="width: 100%;" id="promo-cta">{{ settings.promo_modal_cta | escape }}</button>
          <p class="legal" id="promo-legal-modal">{{ settings.promo_legal | escape }}</p>

          {% if form.errors %}
            <div id="promo-error" class="success" style="color: #7a163c;">{{ form.errors | default_errors }}</div>
          {% endif %}
        {% endif %}
      {% endform %}
    </div>
  </div>
{%- endunless -%}

{% schema %}
{
  "name": "Glazur header",
  "class": "section-glazur-header",
  "settings": [],
  "presets": [{ "name": "Glazur header" }]
}
{% endschema %}
