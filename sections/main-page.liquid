{% liquid
  assign size_page_setting = settings.footer_page_size_guide
  assign is_glazur_size_guide = false
  if page.handle == 'size-guide'
    assign is_glazur_size_guide = true
  elsif size_page_setting != blank and size_page_setting.id == page.id
    assign is_glazur_size_guide = true
  endif

  assign policy_like = false
  if page.handle == 'care' or page.handle == 'faq' or is_glazur_size_guide or page.handle == 'shipping-returns'
    assign policy_like = true
  endif
%}

{% if policy_like %}
  <div class="shopify-policy__container rte glazur-page--policy-like">
    <h1 class="shopify-policy__title">{{ page.title }}</h1>
    {% if page.handle == 'care' %}
      {% render 'glazur-page-body-care' %}
    {% elsif is_glazur_size_guide %}
      {% render 'glazur-page-body-size-guide' %}
    {% elsif page.handle == 'shipping-returns' %}
      {% render 'glazur-page-body-shipping-returns' %}
    {% elsif page.handle == 'faq' %}
      {% render 'glazur-page-body-faq' %}
    {% endif %}
  </div>
{% else %}
  <article class="section-main-page container rte" style="padding: 2rem 1rem; max-width: 800px; margin: 0 auto;">
    <h1 style="font-family: var(--font-heading, Syne, sans-serif);">{{ page.title }}</h1>
    {{ page.content }}
  </article>
{% endif %}

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "section-main-page",
  "settings": []
}
{% endschema %}
