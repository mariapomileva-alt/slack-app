<section class="section-main-product container" style="padding: 2rem 1rem;">
  {%- assign lifestyle_gallery = product.metafields.custom.lifestyle_gallery.value -%}
  <style>
    .product-page {
      display: grid;
      gap: 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .product-gallery {
      display: grid;
      gap: 0.85rem;
    }

    .product-gallery__viewport {
      position: relative;
    }

    .product-gallery__track {
      display: flex;
      gap: 0.75rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      padding-bottom: 0.25rem;
    }

    .product-gallery__slide {
      flex: 0 0 100%;
      scroll-snap-align: start;
      border-radius: 0.35rem;
      overflow: hidden;
      background: transparent;
    }

    .product-gallery__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 50%;
      border: 1px solid rgba(44, 18, 32, 0.18);
      background: rgba(255, 255, 255, 0.92);
      color: #4a1536;
      font-size: 1.2rem;
      line-height: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 2;
      box-shadow: 0 3px 12px rgba(44, 18, 32, 0.12);
    }

    .product-gallery__arrow:hover {
      background: #fff;
      border-color: rgba(44, 18, 32, 0.35);
    }

    .product-gallery__arrow:disabled {
      opacity: 0.35;
      cursor: default;
      box-shadow: none;
    }

    .product-gallery__arrow--prev {
      left: 0.55rem;
    }

    .product-gallery__arrow--next {
      right: 0.55rem;
    }

    .product-gallery__slide img,
    .product-gallery__slide video,
    .product-gallery__slide model-viewer,
    .product-gallery__slide iframe {
      display: block;
      width: 100%;
      height: auto;
    }

    .product-gallery__slide img {
      aspect-ratio: 4 / 5;
      object-fit: cover;
      object-position: center top;
    }

    .product-gallery__thumbs {
      display: flex;
      gap: 0.5rem;
      overflow-x: auto;
      padding-bottom: 0.2rem;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
    }

    .product-gallery__thumb {
      flex: 0 0 4.5rem;
      display: block;
      border-radius: 0.3rem;
      overflow: hidden;
      background: #f7f3f1;
      border: 1px solid rgba(44, 18, 32, 0.08);
    }

    .product-gallery__thumb img {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      object-fit: cover;
    }

    .product-lifestyle {
      max-width: 1100px;
      margin: 2rem auto 0;
    }

    .product-lifestyle__heading {
      margin: 0 0 1rem;
      font-family: var(--font-heading, Syne, sans-serif);
      font-size: clamp(1.25rem, 2vw, 1.75rem);
    }

    .product-lifestyle__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .product-lifestyle__item {
      border-radius: 0.35rem;
      overflow: hidden;
      background: #f7f3f1;
    }

    .product-lifestyle__item img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      aspect-ratio: 4 / 5;
    }

    .product-one-size {
      margin-top: 1.4rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(44, 18, 32, 0.14);
    }

    .product-one-size__title {
      margin: 0 0 0.35rem;
      font-family: var(--font-ui, Syne, sans-serif);
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-plum, #4a1536);
    }

    .product-one-size__lead {
      margin: 0 0 0.75rem;
      color: var(--color-ink-muted, #5c4550);
      line-height: 1.5;
      font-size: 0.92rem;
    }

    .product-one-size__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.55rem;
    }

    .product-one-size__item {
      margin: 0;
    }

    .product-one-size__item img {
      width: 100%;
      height: auto;
      display: block;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border-radius: 0.2rem;
    }

    .product-one-size__caption {
      display: block;
      margin-top: 0.28rem;
      color: var(--color-ink-muted, #5c4550);
      font-size: 0.74rem;
      line-height: 1.35;
    }

    .product-shipping-note {
      margin: 0 0 1rem;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.34rem 0.6rem;
      border: 1px solid rgba(74, 21, 54, 0.18);
      background: rgba(255, 255, 255, 0.65);
      color: var(--color-plum, #4a1536);
      font-family: var(--font-ui, Syne, sans-serif);
      font-size: 0.72rem;
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    @media (min-width: 901px) {
      .product-page {
        grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
        align-items: start;
      }

      .product-lifestyle__grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }
  </style>

  <div class="product-page">
    {% if product.media.size > 0 %}
      <div class="product-gallery">
        <div class="product-gallery__viewport">
          {% if product.media.size > 1 %}
            <button type="button" class="product-gallery__arrow product-gallery__arrow--prev" aria-label="Previous image">‹</button>
            <button type="button" class="product-gallery__arrow product-gallery__arrow--next" aria-label="Next image">›</button>
          {% endif %}
          <div class="product-gallery__track" aria-label="Product media gallery">
            {% for media in product.media %}
              <div class="product-gallery__slide" id="ProductMedia-{{ section.id }}-{{ media.id }}">
                {% case media.media_type %}
                  {% when 'image' %}
                    {% assign img_alt = media.alt | default: product.title %}
                    {{
                      media
                      | image_url: width: 1600
                      | image_tag: loading: 'lazy', alt: img_alt
                    }}
                  {% when 'video' %}
                    {{ media | media_tag: image_size: '1600x', controls: true, preload: 'metadata' }}
                  {% when 'external_video' %}
                    {{ media | media_tag }}
                  {% else %}
                    {{ media | media_tag }}
                {% endcase %}
              </div>
            {% endfor %}
          </div>
        </div>

        {% if product.media.size > 1 %}
          <div class="product-gallery__thumbs" aria-label="Product gallery thumbnails">
            {% for media in product.media %}
              {% assign thumb_alt = media.alt | default: product.title %}
              <a class="product-gallery__thumb" href="#ProductMedia-{{ section.id }}-{{ media.id }}" aria-label="Open media {{ forloop.index }}">
                {% if media.preview_image %}
                  {{
                    media.preview_image
                    | image_url: width: 240
                    | image_tag: loading: 'lazy', alt: thumb_alt
                  }}
                {% endif %}
              </a>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
    <div>
      <h1 style="font-family: var(--font-heading, Syne, sans-serif);">{{ product.title }}</h1>
      <p class="product__price" style="font-size: 1.25rem; margin: 1rem 0;">{{ product.selected_or_first_available_variant.price | money }}</p>
      <p class="product-shipping-note">Free shipping from $150</p>
      <div class="rte" style="margin-bottom: 1.5rem;">{{ product.description }}</div>
      {% form 'product', product, class: 'product-form' %}
        <select name="id" aria-label="Variant">
          {% for variant in product.variants %}
            <option
              value="{{ variant.id }}"
              {% if variant == product.selected_or_first_available_variant %}
                selected
              {% endif %}
              {% unless variant.available %}
                disabled
              {% endunless %}
            >
              {{ variant.title }} — {{ variant.price | money }}
            </option>
          {% endfor %}
        </select>
        <button
          type="submit"
          name="add"
          class="btn btn--fill"
          style="margin-top: 1rem; display: block;"
          {% unless product.selected_or_first_available_variant.available %}
            disabled
          {% endunless %}
        >
          {% if product.selected_or_first_available_variant.available %}
            {{ 'products.product.add_to_cart' | t }}
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>
      {% endform %}

      {% if section.settings.one_size_enabled %}
        <div class="product-one-size">
          <h3 class="product-one-size__title">{{ section.settings.one_size_title | escape }}</h3>
          {% if section.settings.one_size_lead != blank %}
            <p class="product-one-size__lead">{{ section.settings.one_size_lead | escape }}</p>
          {% endif %}
          <div class="product-one-size__grid">
            {% if section.settings.one_size_image_1 != blank %}
              <figure class="product-one-size__item">
                {{
                  section.settings.one_size_image_1
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', alt: section.settings.one_size_caption_1 | default: 'One size fit example'
                }}
                {% if section.settings.one_size_caption_1 != blank %}
                  <figcaption class="product-one-size__caption">{{ section.settings.one_size_caption_1 | escape }}</figcaption>
                {% endif %}
              </figure>
            {% endif %}
            {% if section.settings.one_size_image_2 != blank %}
              <figure class="product-one-size__item">
                {{
                  section.settings.one_size_image_2
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', alt: section.settings.one_size_caption_2 | default: 'One size fit example'
                }}
                {% if section.settings.one_size_caption_2 != blank %}
                  <figcaption class="product-one-size__caption">{{ section.settings.one_size_caption_2 | escape }}</figcaption>
                {% endif %}
              </figure>
            {% endif %}
            {% if section.settings.one_size_image_3 != blank %}
              <figure class="product-one-size__item">
                {{
                  section.settings.one_size_image_3
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', alt: section.settings.one_size_caption_3 | default: 'One size fit example'
                }}
                {% if section.settings.one_size_caption_3 != blank %}
                  <figcaption class="product-one-size__caption">{{ section.settings.one_size_caption_3 | escape }}</figcaption>
                {% endif %}
              </figure>
            {% endif %}
            {% if section.settings.one_size_image_4 != blank %}
              <figure class="product-one-size__item">
                {{
                  section.settings.one_size_image_4
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', alt: section.settings.one_size_caption_4 | default: 'One size fit example'
                }}
                {% if section.settings.one_size_caption_4 != blank %}
                  <figcaption class="product-one-size__caption">{{ section.settings.one_size_caption_4 | escape }}</figcaption>
                {% endif %}
              </figure>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  {% if lifestyle_gallery != blank %}
    <div class="product-lifestyle">
      <h2 class="product-lifestyle__heading">Seen in real life</h2>
      <div class="product-lifestyle__grid">
        {% for image in lifestyle_gallery %}
          <div class="product-lifestyle__item">
            {{
              image
              | image_url: width: 900
              | image_tag: loading: 'lazy', alt: product.title
            }}
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <script>
    (function () {
      var root = document.currentScript && document.currentScript.closest('.section-main-product');
      if (!root) return;
      var track = root.querySelector('.product-gallery__track');
      var prev = root.querySelector('.product-gallery__arrow--prev');
      var next = root.querySelector('.product-gallery__arrow--next');
      if (!track || !prev || !next) return;

      function slideWidth() {
        var first = track.querySelector('.product-gallery__slide');
        return first ? first.getBoundingClientRect().width + 12 : track.clientWidth;
      }

      function updateState() {
        var max = track.scrollWidth - track.clientWidth - 1;
        prev.disabled = track.scrollLeft <= 1;
        next.disabled = track.scrollLeft >= max;
      }

      prev.addEventListener('click', function () {
        track.scrollBy({ left: -slideWidth(), behavior: 'smooth' });
      });
      next.addEventListener('click', function () {
        track.scrollBy({ left: slideWidth(), behavior: 'smooth' });
      });
      track.addEventListener('scroll', updateState, { passive: true });
      window.addEventListener('resize', updateState);
      updateState();
    })();
  </script>
</section>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "paragraph",
      "content": "The product page now shows all product media as a swipeable gallery. To add the lower lifestyle gallery, create a product metafield `custom.lifestyle_gallery` as a list of files and attach your model / real-life photos there."
    },
    {
      "type": "header",
      "content": "One size fit section"
    },
    {
      "type": "checkbox",
      "id": "one_size_enabled",
      "label": "Show one size fit section",
      "default": true
    },
    {
      "type": "text",
      "id": "one_size_title",
      "label": "Section title",
      "default": "One size on different body types"
    },
    {
      "type": "textarea",
      "id": "one_size_lead",
      "label": "Section text",
      "default": "See how this piece looks on different body types. Use real fit photos and add short notes with height or measurements."
    },
    {
      "type": "image_picker",
      "id": "one_size_image_1",
      "label": "Photo 1"
    },
    {
      "type": "text",
      "id": "one_size_caption_1",
      "label": "Photo 1 caption",
      "default": "Height 162 cm"
    },
    {
      "type": "image_picker",
      "id": "one_size_image_2",
      "label": "Photo 2"
    },
    {
      "type": "text",
      "id": "one_size_caption_2",
      "label": "Photo 2 caption",
      "default": "Height 170 cm"
    },
    {
      "type": "image_picker",
      "id": "one_size_image_3",
      "label": "Photo 3"
    },
    {
      "type": "text",
      "id": "one_size_caption_3",
      "label": "Photo 3 caption",
      "default": "Height 176 cm"
    },
    {
      "type": "image_picker",
      "id": "one_size_image_4",
      "label": "Photo 4"
    },
    {
      "type": "text",
      "id": "one_size_caption_4",
      "label": "Photo 4 caption",
      "default": "Height 182 cm"
    }
  ]
}
{% endschema %}
