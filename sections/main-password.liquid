<section style="padding: 2rem; text-align: center; max-width: 420px;">
  <h1 style="font-family: var(--font-heading, Syne, sans-serif);">{{ shop.name }}</h1>
  <p>Opening soon</p>
  {% form 'storefront_password' %}
    <label for="password" class="sr-only">Password</label>
    <input type="password" name="password" id="password" placeholder="Password" style="width: 100%; padding: 0.5rem; margin: 1rem 0;">
    <button type="submit" class="btn btn--fill" style="width: 100%;">Enter</button>
  {% endform %}
</section>

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "settings": []
}
{% endschema %}
