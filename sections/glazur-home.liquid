<div class="glazur-home-root">
  {% assign hero_video_src = section.settings.hero_video_url | strip %}
  {% if hero_video_src != blank %}
    <section class="ru-hero ru-hero--video" aria-labelledby="hero-title">
      <video
        class="ru-hero__video-media"
        src="{{ hero_video_src | escape }}"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      ></video>
      <div class="ru-hero__video-overlay">
        <div class="ru-hero__video-copy">
          <p class="ru-hero__eyebrow">Natural fabrics · Paris-designed</p>
          <h1 id="hero-title">{{ section.settings.hero_heading | escape }}</h1>
          <p class="ru-hero__lead">{{ section.settings.hero_lead | escape }}</p>
          <div class="ru-hero__actions">
            <a class="btn btn--hero-pink" href="{% render 'glazur-collection-url', key: 'default' %}">View catalog</a>
            <a class="btn" href="#story">Read more</a>
          </div>
        </div>
      </div>
    </section>
  {% else %}
    <section class="ru-hero" aria-labelledby="hero-title">
      <div class="ru-hero__grid">
        <div class="ru-hero__copy">
          <p class="ru-hero__eyebrow">Natural fabrics · Paris-designed</p>
          <h1 id="hero-title">{{ section.settings.hero_heading | escape }}</h1>
          <p class="ru-hero__lead">{{ section.settings.hero_lead | escape }}</p>
          <div class="ru-hero__actions">
            <a class="btn btn--hero-pink" href="{% render 'glazur-collection-url', key: 'default' %}">View catalog</a>
            <a class="btn" href="#story">Read more</a>
          </div>
        </div>
        <figure class="ru-hero__figure">
          {% if section.settings.hero_image != blank %}
            {% assign hero_alt = section.settings.hero_image.alt | default: shop.name %}
            {{
              section.settings.hero_image
              | image_url: width: 1200
              | image_tag: class: 'ru-hero__img', loading: 'eager', decoding: 'async', alt: hero_alt
            }}
          {% else %}
            <img
              class="ru-hero__img"
              src="{{ 'glazur-hero-pink-studio.png' | asset_url }}"
              width="538"
              height="716"
              alt="{{ shop.name }} — hero"
              loading="eager"
              decoding="async"
            >
          {% endif %}
        </figure>
      </div>
    </section>
  {% endif %}

  <section id="about-products" class="ru-products" aria-labelledby="products-title">
    {% assign home_product_1 = section.settings.home_product_1 %}
    {% assign home_product_2 = section.settings.home_product_2 %}
    {% assign home_product_3 = section.settings.home_product_3 %}
    <div class="container">
      <p class="ru-products__eyebrow">Products</p>
      <h2 id="products-title" class="ru-products__title">Featured pieces</h2>
      <p class="ru-products__lead">A few favorites from the current line — tap through to the shop.</p>
      <div class="ru-products__grid">
        <article class="ru-product-card">
          <a class="ru-product-card__link" href="{% if home_product_1 != blank %}{{ home_product_1.url }}{% else %}{% render 'glazur-collection-url', key: 'stripes' %}{% endif %}">
            <figure class="ru-product-card__figure">
              {% if home_product_1 != blank and home_product_1.featured_image != blank %}
                {% assign featured_alt_1 = home_product_1.featured_image.alt | default: home_product_1.title %}
                {{
                  home_product_1.featured_image
                  | image_url: width: 900
                  | image_tag: class: 'ru-product-card__img', width: 768, loading: 'lazy', decoding: 'async', alt: featured_alt_1
                }}
              {% elsif section.settings.featured_image_1 != blank %}
                {% assign featured_alt_1 = section.settings.featured_image_1.alt | default: 'Violet striped top' %}
                {{
                  section.settings.featured_image_1
                  | image_url: width: 900
                  | image_tag: class: 'ru-product-card__img', width: 768, loading: 'lazy', decoding: 'async', alt: featured_alt_1
                }}
              {% else %}
                <img
                  class="ru-product-card__img"
                  src="{{ 'glazur-featured-stripes-violet.png' | asset_url }}"
                  width="768"
                  height="1024"
                  alt="Violet striped top"
                  loading="lazy"
                  decoding="async"
                >
              {% endif %}
            </figure>
            <div class="ru-product-card__meta">
              <h3 class="ru-product-card__name">{% if home_product_1 != blank %}{{ home_product_1.title }}{% else %}Violet striped top{% endif %}</h3>
              <p class="ru-product-card__tag">{% if home_product_1 != blank %}{{ home_product_1.price | money }}{% else %}Parisian stripe tops{% endif %}</p>
            </div>
          </a>
        </article>
        <article class="ru-product-card">
          <a class="ru-product-card__link" href="{% if home_product_2 != blank %}{{ home_product_2.url }}{% else %}{% render 'glazur-collection-url', key: 'blouses' %}{% endif %}">
            <figure class="ru-product-card__figure">
              {% if home_product_2 != blank and home_product_2.featured_image != blank %}
                {% assign featured_alt_2 = home_product_2.featured_image.alt | default: home_product_2.title %}
                {{
                  home_product_2.featured_image
                  | image_url: width: 900
                  | image_tag: class: 'ru-product-card__img', width: 768, loading: 'lazy', decoding: 'async', alt: featured_alt_2
                }}
              {% elsif section.settings.featured_image_2 != blank %}
                {% assign featured_alt_2 = section.settings.featured_image_2.alt | default: 'Blue blouse' %}
                {{
                  section.settings.featured_image_2
                  | image_url: width: 900
                  | image_tag: class: 'ru-product-card__img', width: 768, loading: 'lazy', decoding: 'async', alt: featured_alt_2
                }}
              {% else %}
                <img
                  class="ru-product-card__img"
                  src="{{ 'glazur-muse-1.png' | asset_url }}"
                  width="768"
                  height="1024"
                  alt="Embroidered white blouse detail"
                  loading="lazy"
                  decoding="async"
                >
              {% endif %}
            </figure>
            <div class="ru-product-card__meta">
              <h3 class="ru-product-card__name">{% if home_product_2 != blank %}{{ home_product_2.title }}{% else %}Blue blouse{% endif %}</h3>
              <p class="ru-product-card__tag">{% if home_product_2 != blank %}{{ home_product_2.price | money }}{% else %}Blouses{% endif %}</p>
            </div>
          </a>
        </article>
        <article class="ru-product-card">
          <a class="ru-product-card__link" href="{% if home_product_3 != blank %}{{ home_product_3.url }}{% else %}{% render 'glazur-collection-url', key: 'skirts' %}{% endif %}">
            <figure class="ru-product-card__figure">
              {% if home_product_3 != blank and home_product_3.featured_image != blank %}
                {% assign featured_alt_3 = home_product_3.featured_image.alt | default: home_product_3.title %}
                {{
                  home_product_3.featured_image
                  | image_url: width: 900
                  | image_tag: class: 'ru-product-card__img', width: 768, loading: 'lazy', decoding: 'async', alt: featured_alt_3
                }}
              {% elsif section.settings.featured_image_3 != blank %}
                {% assign featured_alt_3 = section.settings.featured_image_3.alt | default: 'White skirt' %}
                {{
                  section.settings.featured_image_3
                  | image_url: width: 900
                  | image_tag: class: 'ru-product-card__img', width: 768, loading: 'lazy', decoding: 'async', alt: featured_alt_3
                }}
              {% else %}
                <img
                  class="ru-product-card__img"
                  src="{{ 'glazur-muse-5.png' | asset_url }}"
                  width="768"
                  height="1024"
                  alt="Sculpted skirt story"
                  loading="lazy"
                  decoding="async"
                >
              {% endif %}
            </figure>
            <div class="ru-product-card__meta">
              <h3 class="ru-product-card__name">{% if home_product_3 != blank %}{{ home_product_3.title }}{% else %}White skirt{% endif %}</h3>
              <p class="ru-product-card__tag">{% if home_product_3 != blank %}{{ home_product_3.price | money }}{% else %}Skirts{% endif %}</p>
            </div>
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="ru-stripes-story" aria-labelledby="stripes-story-title">
    <div class="container ru-stripes-story__inner">
      <div class="ru-stripes-story__media-wrap">
        <span class="ru-stripes-story__blob ru-stripes-story__blob--pink" aria-hidden="true"></span>
        <span class="ru-stripes-story__blob ru-stripes-story__blob--lime" aria-hidden="true"></span>
        <figure class="ru-stripes-story__media">
          {% if section.settings.stripes_story_image != blank %}
            {% assign stripes_story_alt = section.settings.stripes_story_image.alt | default: 'Parisian stripe tops' %}
            {{
              section.settings.stripes_story_image
              | image_url: width: 1200
              | image_tag: loading: 'lazy', decoding: 'async', alt: stripes_story_alt
            }}
          {% else %}
            <img
              src="{{ 'glazur-featured-stripes-violet.png' | asset_url }}"
              width="768"
              height="1024"
              alt="Parisian stripe tops"
              loading="lazy"
              decoding="async"
            >
          {% endif %}
        </figure>
      </div>
      <div class="ru-stripes-story__copy">
        <p class="ru-stripes-story__eyebrow">Stripe chapter</p>
        <h2 id="stripes-story-title">{{ section.settings.stripes_story_heading | escape }}</h2>
        <p class="ru-stripes-story__lead">{{ section.settings.stripes_story_lead | escape }}</p>
        <a class="btn btn--hero-pink" href="{% render 'glazur-collection-url', key: 'stripes' %}">
          {{ section.settings.stripes_story_cta | escape }}
        </a>
      </div>
    </div>
  </section>

  <section class="ru-muses" aria-labelledby="muses-title">
    <div class="container">
      <p class="ru-muses__eyebrow">Your reviews</p>
      <h2 id="muses-title" class="ru-muses__title">You in Glazur</h2>
      <p class="ru-muses__sub">our beautiful muses</p>
      <div class="ru-muses__gallery">
        <figure>
          {% if section.settings.muse_image_1 != blank %}
            {% assign muse_alt_1 = section.settings.muse_image_1.alt | default: 'Glazur muse 1' %}
            {{
              section.settings.muse_image_1
              | image_url: width: 900
              | image_tag: width: 768, loading: 'lazy', decoding: 'async', alt: muse_alt_1
            }}
          {% else %}
            <img
              src="{{ 'glazur-muse-1.png' | asset_url }}"
              width="768"
              height="1024"
              alt="Glazur muse — pink striped top with floral applique and white skirt on a blue sofa"
              loading="lazy"
              decoding="async"
            >
          {% endif %}
        </figure>
        <figure>
          {% if section.settings.muse_image_2 != blank %}
            {% assign muse_alt_2 = section.settings.muse_image_2.alt | default: 'Glazur muse 2' %}
            {{
              section.settings.muse_image_2
              | image_url: width: 900
              | image_tag: width: 682, loading: 'lazy', decoding: 'async', alt: muse_alt_2
            }}
          {% else %}
            <img
              src="{{ 'glazur-muse-4.png' | asset_url }}"
              width="682"
              height="1024"
              alt="Glazur muse 2"
              loading="lazy"
              decoding="async"
            >
          {% endif %}
        </figure>
        <figure>
          {% if section.settings.muse_image_3 != blank %}
            {% assign muse_alt_3 = section.settings.muse_image_3.alt | default: 'Glazur muse 3' %}
            {{
              section.settings.muse_image_3
              | image_url: width: 900
              | image_tag: width: 768, loading: 'lazy', decoding: 'async', alt: muse_alt_3
            }}
          {% else %}
            <img
              src="{{ 'glazur-muse-3.png' | asset_url }}"
              width="768"
              height="1024"
              alt="Glazur muse 3"
              loading="lazy"
              decoding="async"
            >
          {% endif %}
        </figure>
      </div>
      <div class="ru-muses__footer">
        {% assign instagram_href = settings.social_instagram | default: 'https://www.instagram.com/' %}
        <a class="btn" href="{{ instagram_href | escape }}" target="_blank" rel="noopener noreferrer">See more on Instagram</a>
      </div>
    </div>
  </section>

  <section id="story" class="ru-philosophy">
    <div class="container">
      <h2 class="ru-philosophy__h"><span class="ru-hash">#</span> Soft transformation</h2>
      <div class="ru-philosophy__body">
        {% if section.settings.story_richtext != blank %}
          {{ section.settings.story_richtext }}
        {% else %}
          {% render 'glazur-story-default' %}
        {% endif %}
      </div>
    </div>
  </section>

  <section class="ru-catalog" aria-labelledby="catalog-title">
    {%- liquid
      assign ig_href = settings.social_instagram | default: 'https://www.instagram.com/'
      assign fb_href = settings.social_facebook | default: 'https://www.facebook.com/'
      assign pt_href = settings.social_pinterest | default: 'https://www.pinterest.com/'
      assign yt_href = settings.social_youtube | default: 'https://www.youtube.com/'
    -%}
    <div class="container ru-catalog__inner">
      <h2 id="catalog-title" class="ru-catalog__title">Follow Glazur</h2>
      <nav class="ru-catalog__links" aria-label="Social links">
        <a href="{{ ig_href | escape }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="currentColor" d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2zm0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5a3.95 3.95 0 0 0 3.95 3.95h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95h-8.5zm8.95 1.45a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2zM12 7a5 5 0 1 1 0 10a5 5 0 0 1 0-10zm0 1.8a3.2 3.2 0 1 0 0 6.4a3.2 3.2 0 0 0 0-6.4z"/></svg>
        </a>
        <a href="{{ fb_href | escape }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="currentColor" d="M13.5 21v-7.4h2.5l.4-2.9h-2.9V8.85c0-.84.23-1.41 1.44-1.41h1.54V4.85a20.3 20.3 0 0 0-2.24-.11c-2.21 0-3.72 1.34-3.72 3.82v2.14H8v2.9h2.47V21h3.03z"/></svg>
        </a>
        <a href="{{ pt_href | escape }}" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="currentColor" d="M12 2a10 10 0 0 0-3.58 19.34c-.05-.83-.1-2.11.02-3.01l1.06-4.49s-.26-.52-.26-1.29c0-1.21.7-2.12 1.57-2.12.74 0 1.1.56 1.1 1.22 0 .75-.48 1.86-.72 2.89-.21.87.44 1.58 1.3 1.58 1.56 0 2.76-1.65 2.76-4.03 0-2.1-1.5-3.57-3.65-3.57-2.49 0-3.95 1.87-3.95 3.8 0 .75.29 1.56.66 2 .07.08.08.15.06.24l-.24.99c-.04.16-.13.2-.3.12-1.12-.52-1.83-2.15-1.83-3.47 0-2.82 2.05-5.41 5.9-5.41 3.1 0 5.5 2.21 5.5 5.16 0 3.08-1.94 5.56-4.63 5.56-.9 0-1.75-.47-2.03-1.03l-.56 2.14c-.2.78-.74 1.76-1.1 2.36A10 10 0 1 0 12 2z"/></svg>
        </a>
        <a href="{{ yt_href | escape }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="currentColor" d="M21.58 7.19a2.98 2.98 0 0 0-2.1-2.1C17.62 4.6 12 4.6 12 4.6s-5.62 0-7.48.49a2.98 2.98 0 0 0-2.1 2.1C1.93 9.05 1.93 12 1.93 12s0 2.95.49 4.81a2.98 2.98 0 0 0 2.1 2.1c1.86.49 7.48.49 7.48.49s5.62 0 7.48-.49a2.98 2.98 0 0 0 2.1-2.1c.49-1.86.49-4.81.49-4.81s0-2.95-.49-4.81zM10.2 14.97V9.03L15.36 12l-5.16 2.97z"/></svg>
        </a>
      </nav>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Glazur home",
  "tag": "section",
  "class": "section-glazur-home",
  "settings": [
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero heading",
      "default": "This is your fairy tale"
    },
    {
      "type": "textarea",
      "id": "hero_lead",
      "label": "Hero lead",
      "default": "Clothing that makes you feel different. Natural fabrics, comfort that never competes with beauty, and silhouettes that build a look without effort."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (optional — falls back to theme asset)"
    },
    {
      "type": "url",
      "id": "hero_video_url",
      "label": "Hero video URL (full screen)",
      "info": "Paste a direct .mp4 link from Shopify Files (Content → Files). When set, hero switches to full-screen video under header."
    },
    {
      "type": "richtext",
      "id": "story_richtext",
      "label": "Story / philosophy",
      "default": "<p>Glazur is a gentle shift in how you see yourself and move through your day. We believe in soft transformation—not a dramatic reinvention, but a quiet return to what already feels right: natural fabrics, clean silhouettes, and thoughtful details you notice when you slow down.</p><p>Like glaze on a dessert, a subtle finish can change the entire impression. Our pieces work the same way—they elevate your look without pulling focus from you.</p><p>We work in cotton, linen, and tactile fabrics you'll want to reach for on repeat. Lace, embroidery, a carefully placed button—each piece carries a signature detail, something small that makes an everyday moment feel a little more considered.</p><p>We're not here to chase trends. We're after a quieter kind of femininity: ease, confidence, and letting beauty live in the details. From a busy morning to a slower afternoon, it's not just what you wear—it's how your day feels when everything falls into place.</p>"
    },
    {
      "type": "header",
      "content": "You in Glazur gallery"
    },
    {
      "type": "image_picker",
      "id": "muse_image_1",
      "label": "Muse image 1"
    },
    {
      "type": "image_picker",
      "id": "muse_image_2",
      "label": "Muse image 2"
    },
    {
      "type": "image_picker",
      "id": "muse_image_3",
      "label": "Muse image 3"
    },
    {
      "type": "header",
      "content": "Featured pieces images"
    },
    {
      "type": "image_picker",
      "id": "featured_image_1",
      "label": "Featured image 1"
    },
    {
      "type": "image_picker",
      "id": "featured_image_2",
      "label": "Featured image 2"
    },
    {
      "type": "image_picker",
      "id": "featured_image_3",
      "label": "Featured image 3"
    },
    {
      "type": "header",
      "content": "Featured products (real product cards)"
    },
    {
      "type": "product",
      "id": "home_product_1",
      "label": "Card 1 product (violet striped top)"
    },
    {
      "type": "product",
      "id": "home_product_2",
      "label": "Card 2 product (blue blouse)"
    },
    {
      "type": "product",
      "id": "home_product_3",
      "label": "Card 3 product (white skirt)"
    },
    {
      "type": "header",
      "content": "Stripe story section"
    },
    {
      "type": "text",
      "id": "stripes_story_heading",
      "label": "Stripe story heading",
      "default": "The stripes story"
    },
    {
      "type": "textarea",
      "id": "stripes_story_lead",
      "label": "Stripe story text",
      "default": "Our signature telnashki blend Paris ease with soft femininity. Lightweight cotton, flattering lines, and one detail that makes every look feel unmistakably Glazur."
    },
    {
      "type": "text",
      "id": "stripes_story_cta",
      "label": "Stripe story button",
      "default": "Explore stripe tops"
    },
    {
      "type": "image_picker",
      "id": "stripes_story_image",
      "label": "Stripe story image"
    }
  ],
  "presets": [{ "name": "Glazur home" }]
}
{% endschema %}
